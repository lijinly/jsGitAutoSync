# GitHub Personal Access Token (需要 repo 权限)
GITHUB_PAT=ghp_xxxxxxxxxxxx

# GitHub 仓库地址（PAT认证格式）
REPO_URL=https://ghp_xxxxxxxxxxxx@github.com/user/sync-repo.git

# 分支名
BRANCH=main

# 本地同步目录（绝对路径）
SYNC_DIR=D:/SyncFolder

# 定时 pull 间隔（秒）
PULL_INTERVAL=30

# 本机标识名（用于日志和 commit 追溯）
PC_NAME=MyPC

# Git 用户信息（用于自动 commit）
GIT_USER_NAME=SyncBot
GIT_USER_EMAIL=bot@example.com
