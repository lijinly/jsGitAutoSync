{
  "name": "git-file-sync",
  "version": "1.0.0",
  "description": "多PC端文件同步工具 - 基于GitHub仓库，PAT认证，Windows服务+系统托盘",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "install:service": "node src/installer.js --install",
    "uninstall:service": "node src/installer.js --uninstall"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "dotenv": "^16.4.5",
    "node-windows": "^1.0.0-beta.8",
    "simple-git": "^3.27.0",
    "systray2": "^2.0.1",
    "winston": "^3.13.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
