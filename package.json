{
  "name": "git-file-sync",
  "version": "1.0.0",
  "description": "多 PC 端文件同步工具 - 基于 GitHub 仓库，PAT 认证，Windows 服务",
  "main": "src/index.js",
  "bin": "src/index.js",
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "./release"
  },
  "scripts": {
    "start": "node src/index.js",
    "install:service": "node src/installer.js --install",
    "uninstall:service": "node src/installer.js --uninstall"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "dotenv": "^16.4.5",
    "node-windows": "^1.0.0-beta.8",
    "simple-git": "^3.27.0",
    "winston": "^3.13.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
